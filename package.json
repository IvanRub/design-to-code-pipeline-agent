{
  "name": "design-to-code-pipeline-agent",
  "version": "0.1.0",
  "description": "Spec-first multi-agent pipeline: UI component brief → spec → React/TS code → validation",
  "type": "commonjs",
  "bin": {
    "d2c": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pipeline": "ts-node src/cli.ts",
    "orchestrate": "ts-node --project scripts/tsconfig.json scripts/orchestrate.ts",
    "start": "node dist/cli.js",
    "example": "ts-node src/cli.ts examples/payment-form.md"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.185",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  }
}
